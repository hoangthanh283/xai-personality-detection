# Python cache
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.egg
*.whl

# Virtual envs
.venv/
venv/
env/

# Secrets and environment
.env
.env.local

# Raw data (gitignored — download separately)
data/raw/
data/processed/
qdrant_data/

# Model outputs
outputs/models/
outputs/predictions/

# Keep the outputs directory structure
!outputs/.gitkeep
!outputs/models/.gitkeep
!outputs/predictions/.gitkeep
!outputs/reports/.gitkeep

# Jupyter
.ipynb_checkpoints/
*.ipynb

# W&B
wandb/

# MacOS
.DS_Store

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Logs
*.log
logs/
outputs/
assets/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Markdown docs: keep README files and numbered 0N_ notes trackable
**/*.md
!**/README.md
!**/0[0-9]_*.md

docs/BASELINE_RERUN_GUIDE.md
.beads
.claude
